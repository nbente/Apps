<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<title>Utrecht Half Marathon Tracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; overflow: hidden; }
  body {
    font-family: 'DM Sans', sans-serif;
    color: #c8d6e5;
    background: linear-gradient(165deg, #0a0f1e 0%, #0f172a 40%, #131d35 100%);
    -webkit-font-smoothing: antialiased;
  }
  #root { height: 100%; }

/* Page transitions */
.page { position: absolute; inset: 0; overflow-y: auto; padding: 0 16px 100px; transition: transform 0.35s cubic-bezier(.4,0,.2,1), opacity 0.35s ease; }
.page-enter-right { transform: translateX(100%); opacity: 0; }
.page-exit-left { transform: translateX(-30%); opacity: 0.5; }
.page-center { transform: translateX(0); opacity: 1; }

/* Scrollbar */
.page::-webkit-scrollbar { width: 0; }

/* Inputs */
input, textarea, select {
width: 100%; padding: 11px 14px; border-radius: 10px; font-size: 14px;
background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
color: #e8edf5; outline: none; font-family: ‘DM Sans’, sans-serif;
}
input:focus, textarea:focus { border-color: rgba(59,130,246,0.4); }
textarea { resize: vertical; min-height: 72px; }

/* Button base */
button { font-family: ‘DM Sans’, sans-serif; cursor: pointer; border: none; outline: none; -webkit-tap-highlight-color: transparent; }

/* Animations */
@keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
.fade-up { animation: fadeUp 0.45s ease both; }
.fade-up-d1 { animation-delay: 0.06s; }
.fade-up-d2 { animation-delay: 0.12s; }
.fade-up-d3 { animation-delay: 0.18s; }
.fade-up-d4 { animation-delay: 0.24s; }
</style>

</head>
<body>
<div id="root"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/recharts/2.12.7/Recharts.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.9/babel.min.js"></script>

<script type="text/babel">
const { useState, useEffect, useCallback, useRef } = React;
const { ResponsiveContainer, BarChart, Bar, AreaChart, Area, XAxis, YAxis, Tooltip } = Recharts;

/* ───────── Constants ───────── */
const RACE_DATE = new Date("2026-05-31T09:00:00");
const STORAGE_KEY = "utrecht-hm-tracker-v1";

const PLAN = [
  { week:1, label:"Week 1 — Base", runs:[
    { id:"w1r1", day:"Tue", type:"Easy Run", distance:8, pace:"6:15", desc:"Comfortable pace, find your rhythm" },
    { id:"w1r2", day:"Sat", type:"Long Run", distance:12, pace:"6:10", desc:"Steady effort, practice hydration" },
  ]},
  { week:2, label:"Week 2 — Build", runs:[
    { id:"w2r1", day:"Tue", type:"Tempo Run", distance:8, pace:"5:50", desc:"2 km warm-up · 4 km tempo · 2 km cool-down" },
    { id:"w2r2", day:"Sat", type:"Long Run", distance:13, pace:"6:05", desc:"Push the distance, stay relaxed" },
  ]},
  { week:3, label:"Week 3 — Strengthen", runs:[
    { id:"w3r1", day:"Tue", type:"Intervals", distance:8, pace:"5:40", desc:"6 × 800 m at 5:20, 400 m recovery jog" },
    { id:"w3r2", day:"Sat", type:"Long Run", distance:15, pace:"6:00", desc:"Longest run yet — you've got this" },
  ]},
  { week:4, label:"Week 4 — Recovery", runs:[
    { id:"w4r1", day:"Tue", type:"Easy Run", distance:7, pace:"6:20", desc:"Recovery week — keep it gentle" },
    { id:"w4r2", day:"Sat", type:"Long Run", distance:12, pace:"6:10", desc:"Shorter long run, recharge the legs" },
  ]},
  { week:5, label:"Week 5 — Peak", runs:[
    { id:"w5r1", day:"Tue", type:"Tempo Run", distance:10, pace:"5:45", desc:"2 km warm-up · 6 km race pace · 2 km cool-down" },
    { id:"w5r2", day:"Sat", type:"Long Run", distance:17, pace:"5:55", desc:"Dress rehearsal — simulate race morning" },
  ]},
  { week:6, label:"Week 6 — Sharpen", runs:[
    { id:"w6r1", day:"Tue", type:"Intervals", distance:8, pace:"5:35", desc:"5 × 1 km at 5:20, 500 m recovery" },
    { id:"w6r2", day:"Sat", type:"Long Run", distance:14, pace:"5:50", desc:"Controlled & confident at goal pace" },
  ]},
  { week:7, label:"Week 7 — Taper & Race!", runs:[
    { id:"w7r1", day:"Tue", type:"Easy Run", distance:6, pace:"6:15", desc:"Shake out the legs, stay loose" },
    { id:"w7r2", day:"Sun", type:"🏁 RACE DAY", distance:21.1, pace:"5:41", desc:"HiPRO Half Marathon Utrecht — Onder de Domtoren!" },
  ]},
];

const ALL_RUNS = PLAN.flatMap(w => w.runs);

const MOODS = [
  { v:1, emoji:"😫", label:"Awful" },
  { v:2, emoji:"😕", label:"Rough" },
  { v:3, emoji:"😐", label:"Okay" },
  { v:4, emoji:"😊", label:"Good" },
  { v:5, emoji:"🤩", label:"Amazing" },
];
const ENERGY = [
  { v:1, label:"Empty", c:"#ef4444" },
  { v:2, label:"Low", c:"#f97316" },
  { v:3, label:"Medium", c:"#eab308" },
  { v:4, label:"High", c:"#22c55e" },
  { v:5, label:"Super", c:"#06b6d4" },
];
const QUOTES = [
  "The miracle isn't that I finished. The miracle is that I had the courage to start.",
  "Run when you can, walk if you have to, crawl if you must — just never give up.",
  "Every run is a small victory over the voice that says 'stay on the couch.'",
  "The Dom Tower is waiting for you. 🏛️",
  "You don't have to be great to start, but you have to start to be great.",
  "Pain is temporary. Pride is forever.",
  "Trust the training. Trust yourself.",
  "31 mei — jouw dag. 💪",
  "Kilometres don't lie. Every step counts.",
  "You're stronger than you think.",
];

/* ───────── Helpers ───────── */
const daysUntil = () => Math.max(0, Math.ceil((RACE_DATE - new Date()) / 864e5));
const currentWeek = () => { const d = (new Date() - new Date("2026-04-14")) / 864e5; return Math.min(Math.max(1, Math.floor(d/7)+1), 7); };
const load = () => { try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; } catch { return {}; } };
const save = (d) => localStorage.setItem(STORAGE_KEY, JSON.stringify(d));
const todayQuote = () => QUOTES[Math.floor(Date.now()/864e5) % QUOTES.length];

/* ───────── Background Layer ───────── */
function BgGlow() {
  return <>
    <div style={{position:"fixed",top:"-20%",right:"-10%",width:"50vw",height:"50vw",background:"radial-gradient(circle,rgba(59,130,246,0.06) 0%,transparent 70%)",pointerEvents:"none",zIndex:0}} />
    <div style={{position:"fixed",bottom:"-10%",left:"-10%",width:"40vw",height:"40vw",background:"radial-gradient(circle,rgba(14,165,233,0.04) 0%,transparent 70%)",pointerEvents:"none",zIndex:0}} />
  </>;
}

/* ───────── Bottom Nav ───────── */
function Nav({ active, onNav }) {
  const tabs = [
    { id:"dashboard", label:"Dashboard", icon:"◉" },
    { id:"plan", label:"Training", icon:"▤" },
  ];
  return (
    <nav style={{position:"fixed",bottom:0,left:0,right:0,zIndex:50,background:"linear-gradient(180deg,rgba(15,23,42,0.97) 0%,#0a0f1e 100%)",borderTop:"1px solid rgba(255,255,255,0.06)",backdropFilter:"blur(12px)"}}>
      <div style={{display:"flex",maxWidth:480,margin:"0 auto"}}>
        {tabs.map(t=>(
          <button key={t.id} onClick={()=>onNav(t.id)} style={{flex:1,padding:"12px 0 10px",background:"transparent",display:"flex",flexDirection:"column",alignItems:"center",gap:2,color:active===t.id?"#3b82f6":"#4a6a8a",fontSize:11,fontWeight:active===t.id?600:400,transition:"color .2s"}}>
            <span style={{fontSize:20,lineHeight:1}}>{t.icon}</span>{t.label}
          </button>
        ))}
      </div>
    </nav>
  );
}

/* ───────── Header ───────── */
function Header() {
  return (
    <header style={{paddingTop:28,paddingBottom:12,textAlign:"center"}} className="fade-up">
      <div style={{fontSize:11,fontWeight:600,letterSpacing:3,textTransform:"uppercase",color:"#4a8fe7",marginBottom:4}}>Training Tracker</div>
      <h1 style={{fontFamily:"'Playfair Display',serif",fontSize:26,fontWeight:700,color:"#e8edf5",margin:"0 0 2px",lineHeight:1.2}}>Utrecht Half Marathon</h1>
      <div style={{fontSize:13,color:"#6b8db5"}}>31 mei 2026 · Goal: sub 2:00:00</div>
    </header>
  );
}

/* ───────── Dashboard ───────── */
function Dashboard({ logs, onNav }) {
  const completed = Object.values(logs).filter(l=>l.completed===true);
  const totalKm = completed.reduce((s,l)=>s+(parseFloat(l.distance)||0),0);
  const totalRuns = completed.length;
  const avgMood = totalRuns ? (completed.reduce((s,l)=>s+(l.mood||0),0)/totalRuns).toFixed(1) : "—";
  const progress = Math.round((totalRuns/14)*100);
  const days = daysUntil();
  const week = currentWeek();

  const chartData = ALL_RUNS.map(r=>{ const l=logs[r.id]; return { name:`W${r.id[1]}R${r.id[3]}`, planned:r.distance, actual:l?.completed?(parseFloat(l.distance)||0):null, mood:l?.mood||null, energy:l?.energy||null }; });

  return (
    <div style={{maxWidth:480,margin:"0 auto"}}>
      <Header />

      {/* Countdown */}
      <div className="fade-up fade-up-d1" style={{background:"linear-gradient(135deg,#1a2744 0%,#1e3a5f 100%)",borderRadius:16,padding:"24px 20px",marginTop:16,border:"1px solid rgba(74,143,231,0.15)",position:"relative",overflow:"hidden"}}>
        <div style={{position:"absolute",top:-20,right:-20,width:100,height:100,background:"radial-gradient(circle,rgba(59,130,246,0.15) 0%,transparent 70%)"}} />
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}>
          <div>
            <div style={{fontSize:48,fontWeight:700,color:"#e8edf5",fontFamily:"'Playfair Display',serif",lineHeight:1}}>{days}</div>
            <div style={{fontSize:13,color:"#7ba1d4",marginTop:4}}>days to race</div>
          </div>
          <div style={{textAlign:"right"}}>
            <div style={{fontSize:13,color:"#7ba1d4"}}>Week {week} of 7</div>
            <div style={{marginTop:8,background:"rgba(255,255,255,0.08)",borderRadius:100,height:8,width:120,overflow:"hidden"}}>
              <div style={{height:"100%",borderRadius:100,width:`${progress}%`,background:"linear-gradient(90deg,#3b82f6,#06b6d4)",transition:"width .6s ease"}} />
            </div>
            <div style={{fontSize:11,color:"#5a7ea8",marginTop:4}}>{totalRuns}/14 runs · {progress}%</div>
          </div>
        </div>
      </div>

      {/* Quote */}
      <div className="fade-up fade-up-d2" style={{marginTop:14,padding:"14px 18px",borderRadius:12,background:"rgba(59,130,246,0.06)",borderLeft:"3px solid #3b82f6",fontSize:13,fontStyle:"italic",color:"#8eadcf",lineHeight:1.5}}>
        "{todayQuote()}"
      </div>

      {/* Stats */}
      <div className="fade-up fade-up-d3" style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginTop:16}}>
        {[{label:"Total km",value:totalKm.toFixed(1),icon:"📏"},{label:"Avg mood",value:avgMood,icon:"😊"},{label:"Target pace",value:"5:41/km",icon:"⚡"}].map((s,i)=>(
          <div key={i} style={{background:"rgba(255,255,255,0.03)",borderRadius:12,padding:"14px 12px",border:"1px solid rgba(255,255,255,0.05)",textAlign:"center"}}>
            <div style={{fontSize:18,marginBottom:4}}>{s.icon}</div>
            <div style={{fontSize:18,fontWeight:600,color:"#e8edf5"}}>{s.value}</div>
            <div style={{fontSize:11,color:"#5a7ea8",marginTop:2}}>{s.label}</div>
          </div>
        ))}
      </div>

      {/* Distance chart */}
      {totalRuns > 0 && (
        <div className="fade-up fade-up-d4" style={{marginTop:24}}>
          <h3 style={{fontSize:14,fontWeight:600,color:"#7ba1d4",marginBottom:12,letterSpacing:.5}}>Distance Progress</h3>
          <div style={{background:"rgba(255,255,255,0.02)",borderRadius:12,padding:"16px 4px 8px",border:"1px solid rgba(255,255,255,0.04)"}}>
            <ResponsiveContainer width="100%" height={160}>
              <BarChart data={chartData} barGap={2}>
                <XAxis dataKey="name" tick={{fill:"#4a6a8a",fontSize:9}} axisLine={false} tickLine={false} />
                <YAxis tick={{fill:"#4a6a8a",fontSize:10}} axisLine={false} tickLine={false} width={28} />
                <Tooltip contentStyle={{background:"#1a2744",border:"1px solid #2a4060",borderRadius:8,fontSize:12,color:"#c8d6e5"}} />
                <Bar dataKey="planned" fill="rgba(59,130,246,0.18)" radius={[4,4,0,0]} name="Planned" />
                <Bar dataKey="actual" fill="#3b82f6" radius={[4,4,0,0]} name="Actual" />
              </BarChart>
            </ResponsiveContainer>
          </div>
        </div>
      )}

      {/* Mood & Energy */}
      {totalRuns >= 2 && (
        <div style={{marginTop:20}}>
          <h3 style={{fontSize:14,fontWeight:600,color:"#7ba1d4",marginBottom:12,letterSpacing:.5}}>Mood & Energy Trend</h3>
          <div style={{background:"rgba(255,255,255,0.02)",borderRadius:12,padding:"16px 4px 8px",border:"1px solid rgba(255,255,255,0.04)"}}>
            <ResponsiveContainer width="100%" height={130}>
              <AreaChart data={chartData.filter(d=>d.mood!==null)}>
                <XAxis dataKey="name" tick={{fill:"#4a6a8a",fontSize:9}} axisLine={false} tickLine={false} />
                <YAxis domain={[0,5]} tick={{fill:"#4a6a8a",fontSize:10}} axisLine={false} tickLine={false} width={24} />
                <Tooltip contentStyle={{background:"#1a2744",border:"1px solid #2a4060",borderRadius:8,fontSize:12,color:"#c8d6e5"}} />
                <Area type="monotone" dataKey="mood" stroke="#8b5cf6" fill="rgba(139,92,246,0.15)" strokeWidth={2} name="Mood" />
                <Area type="monotone" dataKey="energy" stroke="#06b6d4" fill="rgba(6,182,212,0.1)" strokeWidth={2} name="Energy" />
              </AreaChart>
            </ResponsiveContainer>
          </div>
        </div>
      )}

      {/* CTA */}
      {totalRuns === 0 && (
        <button onClick={()=>onNav("plan")} className="fade-up fade-up-d4" style={{width:"100%",marginTop:24,padding:"14px 0",borderRadius:12,background:"linear-gradient(135deg,#3b82f6,#2563eb)",color:"#fff",fontSize:15,fontWeight:600,boxShadow:"0 4px 20px rgba(59,130,246,0.25)"}}>
          Start Training →
        </button>
      )}
    </div>
  );
}

/* ───────── Training Plan ───────── */
function Plan({ logs, onOpenRun }) {
  const week = currentWeek();
  return (
    <div style={{maxWidth:480,margin:"0 auto"}}>
      <Header />
      <div style={{marginTop:20}}>
        {PLAN.map(w=>(
          <div key={w.week} style={{marginBottom:22}}>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:10}}>
              <div style={{width:28,height:28,borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13,fontWeight:700,
                background:w.week===week?"linear-gradient(135deg,#3b82f6,#06b6d4)":"rgba(255,255,255,0.06)",
                color:w.week===week?"#fff":"#6b8db5"}}>
                {w.week}
              </div>
              <div>
                <span style={{fontSize:14,fontWeight:600,color:w.week===week?"#e8edf5":"#7ba1d4"}}>{w.label}</span>
                {w.week===week && <span style={{fontSize:10,marginLeft:8,padding:"2px 8px",borderRadius:100,background:"rgba(59,130,246,0.2)",color:"#60a5fa"}}>NOW</span>}
              </div>
            </div>

            {w.runs.map(run=>{
              const log = logs[run.id];
              const done = log?.completed===true;
              const skip = log?.completed===false;
              return (
                <div key={run.id} onClick={()=>onOpenRun(run.id)} style={{
                  background:done?"rgba(34,197,94,0.06)":skip?"rgba(239,68,68,0.05)":"rgba(255,255,255,0.025)",
                  border:`1px solid ${done?"rgba(34,197,94,0.15)":skip?"rgba(239,68,68,0.1)":"rgba(255,255,255,0.05)"}`,
                  borderRadius:12,padding:"14px 16px",marginBottom:8,marginLeft:38,cursor:"pointer",
                  transition:"background .2s, border-color .2s",
                }}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
                    <div>
                      <div style={{display:"flex",alignItems:"center",gap:8}}>
                        <span style={{fontSize:11,padding:"2px 8px",borderRadius:6,fontWeight:600,
                          background:run.type.includes("RACE")?"rgba(234,179,8,0.15)":"rgba(59,130,246,0.12)",
                          color:run.type.includes("RACE")?"#eab308":"#60a5fa"}}>{run.type}</span>
                        <span style={{fontSize:12,color:"#5a7ea8"}}>{run.day}</span>
                      </div>
                      <div style={{fontSize:13,color:"#8eadcf",marginTop:6,lineHeight:1.4}}>{run.desc}</div>
                    </div>
                    <div style={{textAlign:"right",flexShrink:0,marginLeft:12}}>
                      <div style={{fontSize:16,fontWeight:600,color:"#e8edf5"}}>{run.distance} km</div>
                      <div style={{fontSize:11,color:"#5a7ea8"}}>{run.pace}/km</div>
                    </div>
                  </div>
                  {done && log && (
                    <div style={{marginTop:10,paddingTop:10,borderTop:"1px solid rgba(255,255,255,0.05)",display:"flex",gap:16,fontSize:12,color:"#7ba1d4"}}>
                      <span>{log.distance} km</span>
                      <span>{log.pace}/km</span>
                      <span>{(MOODS.find(m=>m.v===log.mood)||{}).emoji}</span>
                      <span>⚡{log.energy}/5</span>
                      {log.pain && <span style={{color:"#ef4444"}}>⚠️</span>}
                    </div>
                  )}
                  {skip && <div style={{marginTop:8,fontSize:12,color:"#ef4444",opacity:.7}}>Skipped</div>}
                  {!log && <div style={{marginTop:8,fontSize:11,color:"#4a6a8a"}}>Tap to log this run →</div>}
                </div>
              );
            })}
          </div>
        ))}
      </div>
    </div>
  );
}

/* ───────── Log Run Page ───────── */
function LogRun({ runId, existingLog, onSave, onBack }) {
  const run = ALL_RUNS.find(r=>r.id===runId);
  const [form, setForm] = useState(()=>{
    if (existingLog) return {...existingLog};
    return { completed:null, distance:run?.distance||"", pace:"", mood:0, energy:0, pain:"", notes:"" };
  });
  const set = (k,v) => setForm(p=>({...p,[k]:v}));

  return (
    <div style={{maxWidth:480,margin:"0 auto"}}>
      {/* Back button */}
      <button onClick={onBack} style={{
        display:"flex",alignItems:"center",gap:6,marginTop:24,marginBottom:20,
        background:"none",color:"#4a8fe7",fontSize:14,fontWeight:500,padding:"6px 0",
      }}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        Back to plan
      </button>

      {/* Run info header */}
      <div className="fade-up" style={{background:"linear-gradient(135deg,#1a2744 0%,#1e3a5f 100%)",borderRadius:16,padding:"22px 20px",border:"1px solid rgba(74,143,231,0.15)",marginBottom:24}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
          <div>
            <span style={{fontSize:11,padding:"2px 10px",borderRadius:6,fontWeight:600,
              background:run.type.includes("RACE")?"rgba(234,179,8,0.15)":"rgba(59,130,246,0.12)",
              color:run.type.includes("RACE")?"#eab308":"#60a5fa"}}>{run.type}</span>
            <h2 style={{fontFamily:"'Playfair Display',serif",fontSize:22,color:"#e8edf5",margin:"10px 0 4px"}}>{run.distance} km</h2>
            <p style={{fontSize:13,color:"#7ba1d4",lineHeight:1.4}}>{run.desc}</p>
          </div>
          <div style={{textAlign:"right",flexShrink:0}}>
            <div style={{fontSize:12,color:"#5a7ea8"}}>{run.day}</div>
            <div style={{fontSize:14,fontWeight:600,color:"#8eadcf",marginTop:4}}>{run.pace}/km</div>
          </div>
        </div>
      </div>

      {/* Did you complete it? */}
      <div className="fade-up fade-up-d1" style={{marginBottom:24}}>
        <label style={lbl}>Did you complete this run?</label>
        <div style={{display:"flex",gap:10}}>
          {[{val:true,text:"Yes! ✅",bg:"rgba(34,197,94,0.12)",bc:"rgba(34,197,94,0.3)",c:"#22c55e"},
            {val:false,text:"No ❌",bg:"rgba(239,68,68,0.1)",bc:"rgba(239,68,68,0.25)",c:"#ef4444"}].map(o=>(
            <button key={String(o.val)} onClick={()=>set("completed",o.val)} style={{
              flex:1,padding:"13px 0",borderRadius:10,fontSize:14,fontWeight:600,
              background:form.completed===o.val?o.bg:"rgba(255,255,255,0.03)",
              border:`2px solid ${form.completed===o.val?o.bc:"rgba(255,255,255,0.06)"}`,
              color:form.completed===o.val?o.c:"#5a7ea8",transition:"all .2s",
            }}>{o.text}</button>
          ))}
        </div>
      </div>

      {form.completed===true && <>
        {/* Distance & Pace */}
        <div className="fade-up" style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:22}}>
          <div>
            <label style={lbl}>Distance (km)</label>
            <input type="number" step="0.1" value={form.distance} onChange={e=>set("distance",e.target.value)} placeholder="e.g. 12.5" />
          </div>
          <div>
            <label style={lbl}>Pace (min/km)</label>
            <input type="text" value={form.pace} onChange={e=>set("pace",e.target.value)} placeholder="e.g. 5:45" />
          </div>
        </div>

        {/* Mood */}
        <div className="fade-up" style={{marginBottom:22}}>
          <label style={lbl}>How did it feel?</label>
          <div style={{display:"flex",gap:6}}>
            {MOODS.map(m=>(
              <button key={m.v} onClick={()=>set("mood",m.v)} style={{
                flex:1,padding:"10px 0",borderRadius:10,fontSize:24,
                background:form.mood===m.v?"rgba(139,92,246,0.15)":"rgba(255,255,255,0.03)",
                border:`2px solid ${form.mood===m.v?"rgba(139,92,246,0.35)":"rgba(255,255,255,0.06)"}`,
                transition:"all .2s",
              }}>
                {m.emoji}
                <div style={{fontSize:9,color:form.mood===m.v?"#a78bfa":"#4a6a8a",marginTop:3}}>{m.label}</div>
              </button>
            ))}
          </div>
        </div>

        {/* Energy */}
        <div className="fade-up" style={{marginBottom:22}}>
          <label style={lbl}>Energy Level</label>
          <div style={{display:"flex",gap:6}}>
            {ENERGY.map(e=>(
              <button key={e.v} onClick={()=>set("energy",e.v)} style={{
                flex:1,padding:"10px 4px",borderRadius:10,fontSize:12,fontWeight:600,
                background:form.energy===e.v?`${e.c}18`:"rgba(255,255,255,0.03)",
                border:`2px solid ${form.energy===e.v?`${e.c}50`:"rgba(255,255,255,0.06)"}`,
                color:form.energy===e.v?e.c:"#4a6a8a",transition:"all .2s",
              }}>{e.label}</button>
            ))}
          </div>
        </div>

        {/* Pain */}
        <div className="fade-up" style={{marginBottom:22}}>
          <label style={lbl}>Pain / Injuries</label>
          <input type="text" value={form.pain} onChange={e=>set("pain",e.target.value)} placeholder="None, or describe (e.g. 'left knee tight')" />
        </div>

        {/* Notes */}
        <div className="fade-up" style={{marginBottom:28}}>
          <label style={lbl}>Notes</label>
          <textarea value={form.notes} onChange={e=>set("notes",e.target.value)} placeholder="How was the run? Weather, route, anything..." />
        </div>
      </>}

      {form.completed===false && (
        <div className="fade-up" style={{marginBottom:28}}>
          <label style={lbl}>What happened?</label>
          <textarea value={form.notes} onChange={e=>set("notes",e.target.value)} placeholder="Rest day, injury, busy schedule..." />
        </div>
      )}

      {form.completed!==null && (
        <button onClick={()=>onSave(runId,{...form,loggedAt:new Date().toISOString()})} style={{
          width:"100%",padding:"15px 0",borderRadius:12,
          background:"linear-gradient(135deg,#3b82f6,#2563eb)",
          color:"#fff",fontSize:15,fontWeight:600,
          boxShadow:"0 4px 20px rgba(59,130,246,0.3)",
          marginBottom:20,transition:"opacity .2s",
        }}>
          Save Run Log
        </button>
      )}
    </div>
  );
}

const lbl = {fontSize:11,fontWeight:600,color:"#7ba1d4",letterSpacing:1,textTransform:"uppercase",display:"block",marginBottom:8};

/* ───────── App Shell ───────── */
function App() {
  const [logs, setLogs] = useState(load);
  const [view, setView] = useState("dashboard");    // dashboard | plan | log
  const [logRunId, setLogRunId] = useState(null);
  const [prevView, setPrevView] = useState(null);

  const saveLogs = useCallback((id, data) => {
    setLogs(prev => { const next = {...prev, [id]: data}; save(next); return next; });
    setView("plan");
    setLogRunId(null);
  }, []);

  const openRun = useCallback((id) => {
    setLogRunId(id);
    setPrevView("plan");
    setView("log");
  }, []);

  const goBack = useCallback(() => {
    setView(prevView || "plan");
    setLogRunId(null);
  }, [prevView]);

  const nav = useCallback((v) => {
    setView(v);
    setLogRunId(null);
  }, []);

  return (
    <div style={{position:"relative",height:"100%",overflow:"hidden"}}>
      <BgGlow />

      {/* Dashboard */}
      <div className="page" style={{
        transform: view==="dashboard"?"translateX(0)":"translateX(-30%)",
        opacity: view==="dashboard"?1:0,
        pointerEvents: view==="dashboard"?"auto":"none",
        zIndex: view==="dashboard"?2:1,
      }}>
        <Dashboard logs={logs} onNav={nav} />
      </div>

      {/* Plan */}
      <div className="page" style={{
        transform: view==="plan"?"translateX(0)":view==="log"?"translateX(-30%)":"translateX(100%)",
        opacity: view==="plan"?1:0,
        pointerEvents: view==="plan"?"auto":"none",
        zIndex: view==="plan"?2:1,
      }}>
        <Plan logs={logs} onOpenRun={openRun} />
      </div>

      {/* Log run */}
      <div className="page" style={{
        transform: view==="log"?"translateX(0)":"translateX(100%)",
        opacity: view==="log"?1:0,
        pointerEvents: view==="log"?"auto":"none",
        zIndex: view==="log"?3:1,
      }}>
        {logRunId && <LogRun runId={logRunId} existingLog={logs[logRunId]} onSave={saveLogs} onBack={goBack} />}
      </div>

      {/* Nav — hidden on log page */}
      {view!=="log" && <Nav active={view} onNav={nav} />}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>

</body>
</html>
